# === VIBESHOP ENVIRONMENT CONFIGURATION ===
# Copy this file to .env and fill in your values

# === Application ===
APP_ENV=development
APP_DEBUG=true

# === PostgreSQL / AlloyDB Database (Required) ===
DB_HOST=localhost
DB_PORT=5432
DB_NAME=vibeshop_db
DB_USER=postgres
DB_PASSWORD=postgres
# Alternatively, use single connection string
# DATABASE_URL=postgresql://user:password@host:port/dbname

# === Google Cloud / Vertex AI (Optional - for embeddings) ===
GOOGLE_PROJECT_ID=your_google_cloud_project_id
GOOGLE_REGION=us-central1
GOOGLE_CREDENTIALS_PATH=/path/to/credentials.json

# === Security ===
SECRET_KEY=your_secret_key_here_change_in_production
API_KEY_PREFIX=Bearer

# === WhatsApp Provider (Twilio) (Optional) ===
WHATSAPP_ACCOUNT_SID=your_twilio_account_sid
WHATSAPP_AUTH_TOKEN=your_twilio_auth_token
WHATSAPP_PHONE_NUMBER=+1234567890

# === Payment Provider (Optional) ===
USSD_PROVIDER_URL=https://api.ussd.provider.com
USSD_API_KEY=your_ussd_api_key

# === Feature Flags ===
ENABLE_USSD_PAYMENT=false
ENABLE_SELLER_NOTIFICATIONS=true
ENABLE_CHAT_HANDOFF=true
ENABLE_VECTOR_SEARCH=true

# === Server ===
SERVER_HOST=127.0.0.1
SERVER_PORT=8000
RELOAD=true

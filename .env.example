# === VIBESHOP ENVIRONMENT CONFIGURATION ===

# ===  Google Cloud / Vertex AI (Optional - for embeddings) ===
GOOGLE_PROJECT_ID=your_google_cloud_project_id
GOOGLE_REGION=us-central1

# === PostgreSQL / AlloyDB Database ===
DB_HOST=localhost
DB_PORT=5432
DB_NAME=vibeshop
DB_USER=postgres
DB_PASSWORD=your_database_password

# Alternatively, use single connection string
# DATABASE_URL=postgresql://user:password@host:port/dbname

# === WhatsApp Provider (Twilio) ===
WHATSAPP_TOKEN=your_whatsapp_business_token

# === Feature Flags ===
ENABLE_USSD_PAYMENT=false
ENABLE_SELLER_NOTIFICATIONS=false
ENABLE_CHAT_HANDOFF=true
